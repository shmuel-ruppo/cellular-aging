library(Seurat)
library(SingleCellExperiment)
library(mclust)
library(dplyr)
library(Matrix)
library(ggplot2)
library(rgl)
#library(destiny)
library(TLMoments)
library(sctransform)
#devtools::install_github("satijalab/seurat", ref = "develop")
#BiocManager::install("glmGamPoi")
library(glmGamPoi)
#remotes::install_github("mojaveazure/seurat-disk")
library(SeuratDisk)
library(patchwork)
library(ggiraph)
library(ggiraphExtra)
library(plyr)
library(dplyr)
library(tidyr)
toGRCm38_Ens89 <- function(genes) {
paste0("GRCm38_Ens89_", genes)
}
expressedGenes <- function(object, gene_list) {
relevant_genes <- c()
for (gene in gene_list) {
#if (gene %in% rownames(object@data)) {
if (gene %in% rownames(object@assays$SCT@data)) {
relevant_genes <- c(relevant_genes, gene)
}
}
relevant_genes
}
#calculating number of couts for each cell
myNGenesMark <- function(object) {
object_copy <- object
temp <- data.frame(colSums(object_copy@assays$RNA@data>0))
# temp <- data.frame(colSums(object_copy@data>0))
temp <- t(temp)
colnames(temp) <- colnames(object_copy@assays$RNA@data)
rownames(temp)[1] <- "nGenes"
object_copy@data <- rbind(object_copy@assays$RNA@data, temp)
object_copy
}
MyGeneAvg <- function (object, gene_list, name) {
object_copy <- object
expressed_gene_list <- expressedGenes(object, gene_list)
if (is.null(expressed_gene_list) || length(expressed_gene_list) < 2) {return(NULL)} else {
new_row <- t(as.data.frame(colMeans(object@data[expressed_gene_list,])))
rownames(new_row)[1] <- name
object_copy@data <- rbind(object_copy@data, new_row)
object_copy
}
}
