# In muscle cells, the id is different. I change it to be as in others, so I can run a loop. Did not modify it in the beginning of the code, though it could be neater. No practical need.
allSeuratObj[["Muscle_cells"]]@meta.data <- allSeuratObj[["Muscle_cells"]]@meta.data %>% dplyr::mutate(Sample.ID = sample.name)
allSeuratObj[["Muscle_cells"]]@meta.data$Cell.type = "Muscle_cell"
allSeuratObj %>% names() %>%  lapply(function(objName) {
print(objName)
meta <- allSeuratObj[[objName]]@meta.data
meta <- meta %>% select(Sample.ID, Cell.type, Chronological_age, polycomb_islands_mean_methylation)
# Filter in the same way as in regression
meta <- meta %>% filter(!is.na(polycomb_islands_mean_methylation) & !is.na(Chronological_age))
# This is already filtered (just in the same way as above)
counts <- allExprs_filtered[[objName]]
# The metadata of polycomb_m, age already exists in meta, no need to use it twice
counts <- counts %>% select(-Polycomb_m, -Age)
if (!all(rownames(counts) == rownames(meta)))
stop(objName)
# Combine: metadata first, then counts
combined <- cbind(meta, as.data.frame(as.matrix(counts)))
if(RES_SAVE)
combined %>% write.csv(glue("res_v4/{objName}_counts.csv"), quote=F, row.names=F)
}) %>% invisible()
if(RES_SAVE){
extract_lm %>% names() %>% lapply(function(name) {
df <- extract_lm[[name]]
if(name == "Muscle_cells")
df$Gene_Symbol <- df$Gene_Symbol %>% sapply(function(x) {
parts = strsplit(x, "-") %>% unlist()
if (length(parts) > 1)
parts %>% .[-length(parts)] %>% paste0(collapse="")
else
x
})
df_converted <- df %>% convert_orthologs(gene_input="Gene_Symbol", gene_output ="rownames", input_species="mouse", output_species = "human",non121_strategy =   "drop_both_species")
df_converted %>% mutate(Human_Ortholog_Gene=rownames(.), stat_PolycombM=-log10(PolycombM_Coefficient_Pvalue)*sign(PolycombM_Coefficient_Estimate)) %>% select(Human_Ortholog_Gene, stat_PolycombM) %>% write.csv(glue("res_v4/4gsea/{name}_Polycomb_lm_withZero_byShmuel_fromCreateSubset_toHumanOrtho_4GSEA.csv"),  row.names=F)
df_converted %>% mutate(Human_Ortholog_Gene=rownames(.), stat_Age=-log10(Age_Coefficient_Pvalue)*sign(Age_Coefficient_Estimate)) %>% select(Human_Ortholog_Gene, stat_Age) %>% write.csv(glue("res_v4/4gsea/{name}_Age_lm_withZero_byShmuel_fromCreateSubset_toHumanOrtho_4GSEA.csv"),  row.names=F)
}) %>% invisible()
}
